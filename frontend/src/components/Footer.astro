---
---
<footer class="bg-gradient-to-br from-slate-900 via-purple-950 to-slate-950 text-slate-300 pt-16 pb-8 border-t border-purple-900/30 relative overflow-hidden">
    <!-- Decorative Glow in Background -->
    <div class="absolute left-1/2 bottom-0 -translate-x-1/2 w-96 h-32 bg-[#7F2EE5]/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 md:px-16 relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
            
            <!-- Column 1: Brand Info -->
            <div class="space-y-4">
                <h4 class="text-2xl font-black text-white tracking-wide">
                    The <span class="text-[#9654f5]">cakery</span> house
                </h4>
                <p class="text-xs text-slate-400 font-medium leading-relaxed">
                    Baking happiness fresh daily. We craft 100% pure, premium, and eggless cakes to make your special moments absolutely unforgettable.
                </p>
                <!-- Social Media Icons with Glassy Effect -->
                <div class="flex space-x-3 pt-2">
                    <a href="#" class="w-9 h-9 rounded-full bg-white/5 hover:bg-[#7F2EE5] text-white flex items-center justify-center border border-white/10 hover:border-[#7F2EE5] transition-all duration-300 text-sm shadow-sm">
                        fb
                    </a>
                    <a href="#" class="w-9 h-9 rounded-full bg-white/5 hover:bg-[#7F2EE5] text-white flex items-center justify-center border border-white/10 hover:border-[#7F2EE5] transition-all duration-300 text-sm shadow-sm">
                        ig
                    </a>
                    <a href="#" class="w-9 h-9 rounded-full bg-white/5 hover:bg-[#7F2EE5] text-white flex items-center justify-center border border-white/10 hover:border-[#7F2EE5] transition-all duration-300 text-sm shadow-sm">
                        tw
                    </a>
                </div>
            </div>

            <!-- Column 2: Quick Links -->
            <div class="space-y-4">
                <h5 class="text-sm font-extrabold text-white uppercase tracking-wider border-l-2 border-[#7F2EE5] pl-3">Quick Links</h5>
                <ul class="space-y-2.5 text-xs font-semibold">
                    <li><a href="/" class="hover:text-[#9654f5] transition-colors duration-200 block">Home</a></li>
                    <li><a href="/shop" class="hover:text-[#9654f5] transition-colors duration-200 block">Our Shop</a></li>
                    <li><a href="/about" class="hover:text-[#9654f5] transition-colors duration-200 block">About Us</a></li>
                    <li><a href="/contact" class="hover:text-[#9654f5] transition-colors duration-200 block">Contact Us</a></li>
                </ul>
            </div>

            <!-- Column 3: Contact & Timings -->
            <div class="space-y-4">
                <h5 class="text-sm font-extrabold text-white uppercase tracking-wider border-l-2 border-[#7F2EE5] pl-3">Contact Info</h5>
                <ul class="space-y-3 text-xs font-semibold text-slate-400">
                    <li class="flex items-start gap-2">
                        <span class="text-[#9654f5]">📍</span>
                        <span>123 Sweet Street, Bakery Zone, India</span>
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="text-[#9654f5]">📞</span>
                        <span>+91 98765 43210</span>
                    </li>
                    <li class="flex items-center gap-2">
                        <span class="text-[#9654f5]">⏰</span>
                        <span class="text-slate-300 font-bold">7 AM - 12 AM (Midnight)</span>
                    </li>
                </ul>
            </div>

            <!-- Column 4: Newsletter Subscription -->
            <div class="space-y-4">
                <h5 class="text-sm font-extrabold text-white uppercase tracking-wider border-l-2 border-[#7F2EE5] pl-3">Newsletter</h5>
                <p class="text-xs text-slate-400 font-medium">Subscribe to receive exclusive offers, discount coupons, and sweet updates directly in your inbox.</p>
                
                <form class="flex flex-col sm:flex-row gap-2 pt-1" onsubmit="event.preventDefault();">
                    <input 
                        type="email" 
                        placeholder="Your Email Address" 
                        class="bg-white/5 border border-white/10 rounded-full px-4 py-2 text-xs text-white placeholder-slate-500 focus:outline-none focus:border-[#7F2EE5] focus:bg-white/10 transition-all w-full"
                    />
                    <button class="bg-[#7F2EE5] hover:bg-[#6b24c9] text-white font-bold text-xs px-5 py-2 rounded-full transition-all shrink-0 shadow-lg shadow-purple-950/50">
                        Join
                    </button>
                </form>
            </div>

        </div>

        <!-- Bottom Copyright Area -->
        <div class="border-t border-white/5 pt-8 mt-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-[11px] font-bold text-slate-500">
            <p>&copy; 2026 The Cakery House. All rights reserved.</p>
            <div class="flex space-x-6">
                <a href="#" class="hover:text-slate-300 transition-colors">Privacy Policy</a>
                <a href="#" class="hover:text-slate-300 transition-colors">Terms of Service</a>
            </div>
        </div>
    </div>
</footer>