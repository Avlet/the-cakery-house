  { id: "decor", name: "Decor", icon: "🎈" }
];
---

<Layout title="Shop - The Cakery House">
  <Navbar />
  
  <main class="w-full max-w-[80rem] mx-auto px-6 mt-6 mb-16">
    
    <section class="overflow-x-auto hide-scrollbar mb-8">
      <div id="category-container" class="flex justify-start space-x-4 min-w-max pb-2">
        {categoriesData.map((cat, index) => (
          <button 
            class={`category-btn flex items-center px-8 py-3 rounded-full font-bold text-sm transition-all duration-300 border ${index === 0 ? 'active-tab' : 'inactive-tab'}`}
            data-category={cat.id}
          >
            <span class="text-base mr-2">{cat.icon}</span> {cat.name}
          </button>
        ))}
      </div>
    </section>

    <section>
  <div id="shop-products-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-6">
    
    {allProducts.map((product) => (
      <div class="product-card-container" data-category={product.category}>
        <ProductCard 
          name={product.name}
          price={product.price}
          imageUrl={product.image_url}
          rating={product.rating}
          deliveryTime={product.delivery_time}
        />
      </div>
    ))}

  </div>
</section>
  </main>

  <div id="product-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/40 backdrop-blur-md p-4 animate-in fade-in duration-300">
  <div class="bg-white rounded-[2rem] w-full max-w-lg shadow-[0_30px_60px_rgba(0,0,0,0.2)] overflow-hidden relative">
    <button id="close-modal" class="absolute top-4 right-4 z-10 bg-black/20 hover:bg-black/40 text-white rounded-full w-8 h-8 transition-colors">&times;</button>
    
    <div id="modal-content">
      <img id="modal-img" src="" class="w-full h-64 object-cover" />
      <div class="p-6">
        <h2 id="modal-title" class="text-3xl font-black text-slate-900 mb-2"></h2>
        <div class="flex items-center justify-between mb-4">
          <p id="modal-price" class="text-2xl font-black text-[#7F2EE5]"></p>
          <span class="bg-purple-50 text-[#7F2EE5] px-3 py-1 rounded-full text-xs font-bold">Premium Quality</span>
        </div>
        <p class="text-slate-500 text-sm mb-6">Freshly baked and prepared with the finest ingredients to ensure the perfect taste in every bite.</p>
        
        <button class="w-full bg-[#7F2EE5] hover:bg-purple-700 text-white py-4 rounded-2xl font-bold text-base shadow-lg shadow-purple-500/30 transition-all active:scale-[0.98]">
          Add to Cart
        </button>
      </div>
    </div>
  </div>
</div>
  
  <Footer />
</Layout>

<style>
  .inactive-tab { background: #ffffff; border: 1px solid #e2e8f0; color: #64748b; }
  .active-tab { background: #7F2EE5; border-color: #7F2EE5; color: white; }

  /* Grid alignment */
  #shop-products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); 
    gap: 1.5rem;
  }
  .hide-scrollbar::-webkit-scrollbar { display: none; }
</style>

<script is:inline>
  const modal = document.getElementById('product-modal');
  window.openProductModal = (product) => {
    document.getElementById('modal-title').innerText = product.name;
    document.getElementById('modal-price').innerText = '₹' + product.price;
    document.getElementById('modal-img').src = product.imageUrl;
    modal.classList.remove('hidden');
  };

  document.getElementById('close-modal').addEventListener('click', () => {
    modal.classList.add('hidden');
  });
</script>

<script is:inline>
    const buttons = document.querySelectorAll('.category-btn');
    const products = document.querySelectorAll('.product-card-container');

    buttons.forEach(btn => {
        btn.addEventListener('click', () => {
            const cat = btn.getAttribute('data-category');
            
            // Buttons ka active state
            buttons.forEach(b => {
                b.classList.remove('active-tab');
                b.classList.add('inactive-tab');
            });
            btn.classList.add('active-tab');
            btn.classList.remove('inactive-tab');

            // Filter logic
            products.forEach(card => {
                // Yahan 'grid' ya 'flex' check karein jo aapke main container ki class hai
                if (cat === 'all' || card.getAttribute('data-category') === cat) {
                    card.style.display = 'block'; 
                } else {
                    card.style.display = 'none';
                }
            });
        });
    });
</script>