<!-- Scripts Container -->
<script>
    // 1. Hero Section Slider Logic
    const initHeroSlider = () => {
        const slides = document.querySelectorAll('.slide-content');
        const dots = document.querySelectorAll('.dot-btn');
        if (!slides.length) return;
        
        let currentIdx = 0;
        let intervalId;

        const changeSlide = (nextIdx) => {
            slides[currentIdx].classList.add('opacity-0', 'translate-x-10', 'pointer-events-none');
            slides[currentIdx].classList.remove('opacity-100', 'translate-x-0');
            
            dots[currentIdx].classList.remove('w-6', 'bg-[#7F2EE5]');
            dots[currentIdx].classList.add('w-2', 'bg-purple-200');

            currentIdx = nextIdx;

            slides[currentIdx].classList.remove('opacity-0', 'translate-x-10', 'pointer-events-none');
            slides[currentIdx].classList.add('opacity-100', 'translate-x-0');
            
            dots[currentIdx].classList.remove('w-2', 'bg-purple-200');
            dots[currentIdx].classList.add('w-6', 'bg-[#7F2EE5]');
        };

        const startAutoPlay = () => {
            intervalId = setInterval(() => {
                let next = (currentIdx + 1) % slides.length;
                changeSlide(next);
            }, 3000); // 3 Seconds Interval
        };

        dots.forEach((dot, idx) => {
            dot.addEventListener('click', () => {
                clearInterval(intervalId);
                changeSlide(idx);
                startAutoPlay();
            });
        });

        startAutoPlay();
    };

    // 2. Dual Offers Slider Track Logic (Moves 1-by-1 or view shifts smoothly)
    const initOffersSlider = () => {
        const track = document.querySelector('.offers-slider-track');
        const offerSlides = document.querySelectorAll('.offer-slide-card');
        const offerDots = document.querySelectorAll('.offer-dot-btn');
        if (!track || !offerSlides.length) return;

        let currentStep = 0;
        let offerIntervalId;
        const totalSlides = offerSlides.length;

        const updateOffersView = (stepIndex) => {
            // Remove previous active dot layouts
            offerDots.forEach(dot => {
                dot.classList.remove('w-6', 'bg-[#7F2EE5]');
                dot.classList.add('w-2', 'bg-purple-200');
            });

            currentStep = stepIndex;
            offerDots[currentStep].classList.remove('w-2', 'bg-purple-200');
            offerDots[currentStep].classList.add('w-6', 'bg-[#7F2EE5]');

            // Check if view width supports 2 elements side-by-side
            const isDesktop = window.innerWidth >= 1024;
            let percentageShift = 0;

            if (isDesktop) {
                // If desktop: max steps possible are 3 (showing [0,1], [1,2], [2,3])
                percentageShift = currentStep * 50; 
            } else {
                // For Mobile view stacks full 100% sequentially
                percentageShift = currentStep * 100;
            }

            // Apply smooth track transform shift translation
            track.style.transform = `translateX(-${percentageShift}%)`;
        };

        const startOfferAutoPlay = () => {
            offerIntervalId = setInterval(() => {
                const isDesktop = window.innerWidth >= 1024;
                const maxSteps = isDesktop ? 3 : totalSlides; // Limit steps according to view column constraints
                let nextStep = (currentStep + 1) % maxSteps;
                updateOffersView(nextStep);
            }, 4000);
        };

        offerDots.forEach((dot, idx) => {
            dot.addEventListener('click', () => {
                clearInterval(offerIntervalId);
                updateOffersView(idx);
                startOfferAutoPlay();
            });
        });

        // Initialize state configuration layout mapping
        updateOffersView(0);
        startOfferAutoPlay();

        // Re-calculate setup layouts on screen resize trigger
        window.addEventListener('resize', () => updateOffersView(currentStep));
    };

    // Initialize all sliders mapping
    const runSliders = () => {
        initHeroSlider();
        initOffersSlider();
    };

    runSliders();
    document.addEventListener('astro:after-swap', runSliders);
</script>

<script>
    // Categories Interactive Filters
    const initCategories = () => {
        const buttons = document.querySelectorAll('.category-btn');

        buttons.forEach(button => {
            button.addEventListener('click', () => {
                buttons.forEach(btn => {
                    btn.classList.remove('active-glass');
                    btn.classList.add('glass-btn');
                });
                button.classList.remove('glass-btn');
                button.classList.add('active-glass');
                
                const category = button.getAttribute('data-category');
                console.log(`Selected Category: ${category}`);
            });
        });
    };

    initCategories();
    document.addEventListener('astro:after-swap', initCategories);
</script>