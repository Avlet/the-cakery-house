---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ProductCard from '../components/ProductCard.astro';
import Footer from '../components/Footer.astro';

let products = [];
try {
  const response = await fetch('https://the-cakery-house.onrender.com/api/products/');
  if (response.ok) {
    products = await response.json();
  }
} catch (error) {}

if(products.length === 0) {
	products = [
		{ id: 1, name: "Chocolate Mud", price: 549, image_url: "https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=500", rating: 4.5, delivery_time: "30-45 Min" },
		{ id: 2, name: "Chocolate Kitkat", price: 549, image_url: "https://images.unsplash.com/photo-1606313564200-e75d5e30476c?w=500", rating: 4.5, delivery_time: "30-45 Min" },
		{ id: 3, name: "Chocolate Truffle", price: 549, image_url: "https://images.unsplash.com/photo-1621303837174-89787a7d4729?w=500", rating: 4.5, delivery_time: "30-45 Min" },
		{ id: 4, name: "Keva Recipes", price: 549, image_url: "https://images.unsplash.com/photo-1519869325930-281384150729?w=500", rating: 4.5, delivery_time: "30-45 Min" },
		{ id: 5, name: "Keva Recipes", price: 549, image_url: "https://images.unsplash.com/photo-1603532648955-039310d9ed75?w=500", rating: 4.5, delivery_time: "30-45 Min" }
	];
}

// 4 शानदार ऑफर्स का डेटा ऐरे
const slides = [
	{ tag: "Special Offer", title: "Natural and<br/>Healthy Cakes.", desc: "Experience organic sweetness baked with love. Get 20% off on your first celebration cake order today.", bg: "from-white to-purple-50/30", border: "border-purple-100/70", tagBg: "bg-purple-100/80 text-[#7F2EE5]", btnBg: "bg-[#7F2EE5] hover:bg-[#6b24c9] shadow-purple-500/20", img: "https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=500" },
	{ tag: "Midnight Craving", title: "Baked Fresh,<br/>Delivered At 12 AM.", desc: "Surprise your loved ones right on time! Free delivery on all premium midnight chocolate truffles.", bg: "from-slate-900 via-purple-950 to-slate-900", border: "border-purple-900/40", tagBg: "bg-purple-900/60 border border-purple-700/50 text-purple-300", btnBg: "bg-[#7F2EE5] hover:bg-[#6b24c9] shadow-purple-500/30", img: "https://images.unsplash.com/photo-1606313564200-e75d5e30476c?w=500", darkText: true },
	{ tag: "Custom Creation", title: "Design Your Own<br/>Dream Cake.", desc: "Choose your flavors, tiers, and themes. Our master chefs will bring your imagination to life perfectly.", bg: "from-white to-pink-50/30", border: "border-pink-100/70", tagBg: "bg-pink-50 text-pink-600", btnBg: "bg-pink-600 hover:bg-pink-700 shadow-pink-500/20", img: "https://images.unsplash.com/photo-1621303837174-89787a7d4729?w=500" },
	{ tag: "Festive Joy", title: "Sweeten Your<br/>Celebrations.", desc: "Buy 1 Family-sized Celebration Cake and get 4 complementary premium cupcakes absolutely free.", bg: "from-white to-amber-50/30", border: "border-amber-100/70", tagBg: "bg-amber-50 text-amber-600", btnBg: "bg-amber-500 hover:bg-amber-600 shadow-amber-500/20", img: "https://images.unsplash.com/photo-1519869325930-281384150729?w=500" }
];
---

<Layout title="The Cakery House - Premium Bakery">
    <div class="min-h-screen bg-[#FCF8F5] text-slate-800">
	<Navbar />
	
	<main class="max-w-7xl mx-auto px-4 md:px-16 py-10 space-y-16">
		
		<!-- Hero Section Slider -->
		<section class="flex flex-col lg:flex-row items-center justify-between gap-8 pt-4">
            <div class="w-full lg:w-[65%] bg-gradient-to-br from-white to-purple-50/30 rounded-[32px] p-8 md:p-12 border border-purple-100/70 shadow-[0_20px_50px_-15px_rgba(127,46,229,0.05)] relative min-h-[400px] overflow-hidden flex flex-col justify-between group/slider">
                
                <div class="absolute -top-10 -right-10 w-40 h-40 bg-purple-200/20 rounded-full blur-3xl pointer-events-none"></div>
                <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-pink-200/10 rounded-full blur-3xl pointer-events-none"></div>

                <div class="relative min-h-[260px] md:min-h-[220px]">
                    <div class="slide-content absolute inset-0 transition-all duration-700 ease-in-out flex flex-col md:flex-row md:items-center justify-between gap-6 opacity-100 translate-x-0" data-index="0">
                        <div class="space-y-4 max-w-md">
                            <span class="text-[#7F2EE5] font-bold tracking-widest text-xs uppercase bg-purple-100/80 px-3.5 py-1.5 rounded-full w-max block shadow-sm">Special Offer</span>
                            <h1 class="text-4xl md:text-5xl font-black text-slate-900 tracking-tight leading-[1.15]">
                                Natural and <br/><span class="text-[#7F2EE5]">Healthy Cakes.</span>
                            </h1>
                            <p class="text-slate-500 text-sm md:text-base leading-relaxed font-medium">Experience organic sweetness baked with love. Get 20% off on your first celebration cake order today.</p>
                            <button class="bg-[#7F2EE5] text-white font-bold text-sm px-6 py-3 rounded-full shadow-lg shadow-purple-500/20 hover:bg-[#6b24c9] transition-all transform hover:-translate-y-0.5">Order Now</button>
                        </div>
                        <div class="w-full md:w-44 h-44 rounded-2xl overflow-hidden shadow-md border-2 border-white transform rotate-2 hover:rotate-0 transition-transform duration-300 shrink-0">
                            <img src="https://images.unsplash.com/photo-1578985545062-69928b1d9587?w=500" alt="Natural Cake" class="w-full h-full object-cover" />
                        </div>
                    </div>

                    <div class="slide-content absolute inset-0 transition-all duration-700 ease-in-out flex flex-col md:flex-row md:items-center justify-between gap-6 opacity-0 translate-x-10 pointer-events-none" data-index="1">
                        <div class="space-y-4 max-w-md">
                            <span class="text-indigo-600 font-bold tracking-widest text-xs uppercase bg-indigo-50 px-3.5 py-1.5 rounded-full w-max block shadow-sm">Midnight Craving</span>
                            <h1 class="text-4xl md:text-5xl font-black text-slate-900 tracking-tight leading-[1.15]">
                                Baked Fresh, <br/><span class="text-indigo-600">Delivered At 12 AM.</span>
                            </h1>
                            <p class="text-slate-500 text-sm md:text-base leading-relaxed font-medium">Surprise your loved ones right on time! Free delivery on all premium midnight chocolate truffles.</p>
                            <button class="bg-indigo-600 text-white font-bold text-sm px-6 py-3 rounded-full shadow-lg shadow-indigo-500/20 hover:bg-indigo-700 transition-all transform hover:-translate-y-0.5">Book Slot</button>
                        </div>
                        <div class="w-full md:w-44 h-44 rounded-2xl overflow-hidden shadow-md border-2 border-white transform -rotate-2 hover:rotate-0 transition-transform duration-300 shrink-0">
                            <img src="https://images.unsplash.com/photo-1606313564200-e75d5e30476c?w=500" alt="Midnight Cake" class="w-full h-full object-cover" />
                        </div>
                    </div>

                    <div class="slide-content absolute inset-0 transition-all duration-700 ease-in-out flex flex-col md:flex-row md:items-center justify-between gap-6 opacity-0 translate-x-10 pointer-events-none" data-index="2">
                        <div class="space-y-4 max-w-md">
                            <span class="text-pink-600 font-bold tracking-widest text-xs uppercase bg-pink-50 px-3.5 py-1.5 rounded-full w-max block shadow-sm">Custom Creation</span>
                            <h1 class="text-4xl md:text-5xl font-black text-slate-900 tracking-tight leading-[1.15]">
                                Design Your Own <br/><span class="text-pink-600">Dream Cake.</span>
                            </h1>
                            <p class="text-slate-500 text-sm md:text-base leading-relaxed font-medium">Choose your flavors, tiers, and themes. Our master chefs will bring your imagination to life perfectly.</p>
                            <button class="bg-pink-600 text-white font-bold text-sm px-6 py-3 rounded-full shadow-lg shadow-pink-500/20 hover:bg-pink-700 transition-all transform hover:-translate-y-0.5">Customize</button>
                        </div>
                        <div class="w-full md:w-44 h-44 rounded-2xl overflow-hidden shadow-md border-2 border-white transform rotate-3 hover:rotate-0 transition-transform duration-300 shrink-0">
                            <img src="https://images.unsplash.com/photo-1621303837174-89787a7d4729?w=500" alt="Custom Theme Cake" class="w-full h-full object-cover" />
                        </div>
                    </div>

                    <div class="slide-content absolute inset-0 transition-all duration-700 ease-in-out flex flex-col md:flex-row md:items-center justify-between gap-6 opacity-0 translate-x-10 pointer-events-none" data-index="3">
                        <div class="space-y-4 max-w-md">
                            <span class="text-amber-600 font-bold tracking-widest text-xs uppercase bg-amber-50 px-3.5 py-1.5 rounded-full w-max block shadow-sm">Festive Joy</span>
                            <h1 class="text-4xl md:text-5xl font-black text-slate-900 tracking-tight leading-[1.15]">
                                Sweeten Your <br/><span class="text-amber-600">Celebrations.</span>
                            </h1>
                            <p class="text-slate-500 text-sm md:text-base leading-relaxed font-medium">Buy 1 Family-sized Celebration Cake and get 4 complementary premium cupcakes absolutely free.</p>
                            <button class="bg-amber-500 text-white font-bold text-sm px-6 py-3 rounded-full shadow-lg shadow-amber-500/20 hover:bg-amber-600 transition-all transform hover:-translate-y-0.5">Grab Combo</button>
                        </div>
                        <div class="w-full md:w-44 h-44 rounded-2xl overflow-hidden shadow-md border-2 border-white transform -rotate-3 hover:rotate-0 transition-transform duration-300 shrink-0">
                            <img src="https://images.unsplash.com/photo-1519869325930-281384150729?w=500" alt="Festive Cupcakes" class="w-full h-full object-cover" />
                        </div>
                    </div>
                </div>

                <div class="flex items-center space-x-2 mt-6 z-10">
                    <button class="dot-btn w-6 h-2 bg-[#7F2EE5] rounded-full transition-all duration-300" data-slide="0"></button>
                    <button class="dot-btn w-2 h-2 bg-purple-200 rounded-full transition-all duration-300" data-slide="1"></button>
                    <button class="dot-btn w-2 h-2 bg-purple-200 rounded-full transition-all duration-300" data-slide="2"></button>
                    <button class="dot-btn w-2 h-2 bg-purple-200 rounded-full transition-all duration-300" data-slide="3"></button>
                </div>
            </div>

            <div class="w-full lg:w-[32%] flex justify-center lg:justify-end">
                <div class="w-72 h-72 md:w-80 md:h-80 rounded-full flex items-center justify-center relative group transition-all duration-500 hover:scale-105">
                    <div class="absolute inset-0 bg-[#7F2EE5]/5 rounded-full blur-3xl -z-10 group-hover:bg-[#7F2EE5]/10 transition-colors"></div>
                    <img 
                        src="/logo.png" 
                        alt="The Cakery House Logo" 
                        class="w-full h-full object-contain animate-[spin_50s_linear_infinite] group-hover:animate-[spin_20s_linear_infinite]"
                    />
                </div>
            </div>
        </section>

		<!-- Categories Section with Glass Effect -->
		<section class="overflow-x-auto pb-4 scrollbar-none pt-2">
			<div id="category-container" class="flex space-x-3 min-w-max px-1">
				<button class="category-btn active-glass text-white px-7 py-2.5 rounded-full font-bold text-sm tracking-wide transition-all duration-300 shadow-sm" data-category="all">All</button>
				<button class="category-btn glass-btn text-[#7F2EE5] border border-[#7F2EE5]/30 hover:border-[#7F2EE5] px-7 py-2.5 rounded-full font-semibold text-sm tracking-wide transition-all duration-300" data-category="snacks">Snacks</button>
				<button class="category-btn glass-btn text-[#7F2EE5] border border-[#7F2EE5]/30 hover:border-[#7F2EE5] px-7 py-2.5 rounded-full font-semibold text-sm tracking-wide transition-all duration-300" data-category="desserts">Desserts</button>
				<button class="category-btn glass-btn text-[#7F2EE5] border border-[#7F2EE5]/30 hover:border-[#7F2EE5] px-7 py-2.5 rounded-full font-semibold text-sm tracking-wide transition-all duration-300" data-category="drinks">Drinks</button>
				<button class="category-btn glass-btn text-[#7F2EE5] border border-[#7F2EE5]/30 hover:border-[#7F2EE5] px-7 py-2.5 rounded-full font-semibold text-sm tracking-wide transition-all duration-300" data-category="cakes">Cakes</button>
				<button class="category-btn glass-btn text-[#7F2EE5] border border-[#7F2EE5]/30 hover:border-[#7F2EE5] px-7 py-2.5 rounded-full font-semibold text-sm tracking-wide transition-all duration-300" data-category="chocolates">Chocolates</button>
				<button class="category-btn glass-btn text-[#7F2EE5] border border-[#7F2EE5]/30 hover:border-[#7F2EE5] px-7 py-2.5 rounded-full font-semibold text-sm tracking-wide transition-all duration-300" data-category="decor">Decor</button>
			</div>
		</section>

		<!-- SECTION 1: Popular Picks -->
        <section class="space-y-4 pt-4">
            <div class="flex justify-between items-end border-b border-purple-100/50 pb-2">
                <h3 class="text-2xl font-black text-slate-800 tracking-tight">Popular Picks</h3>
                <a href="/shop?filter=popular" class="text-[#7F2EE5] hover:text-[#6b24c9] font-bold text-sm tracking-wide transition-colors flex items-center gap-1 group">
                    View All <span class="transform group-hover:translate-x-1 transition-transform">&gt;</span>
                </a>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
                {products.slice(0, 5).map(product => (
                    <ProductCard id={product.id} name={product.name} price={product.price} imageUrl={product.image_url} rating={4.5} deliveryTime="30-45 Min" />
                ))}
            </div>
        </section>

		<!-- Features Banner -->
        <section class="relative bg-gradient-to-r from-[#7F2EE5]/10 via-[#7F2EE5]/5 to-transparent rounded-[28px] p-8 border border-[#7F2EE5]/20 shadow-[0_15px_35px_-15px_rgba(127,46,229,0.05)] overflow-hidden">
            <div class="absolute -right-12 -bottom-12 w-32 h-32 bg-[#7F2EE5]/10 rounded-full blur-2xl pointer-events-none"></div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative z-10">
                <div class="flex items-center space-x-5 p-5 bg-white rounded-2xl border border-purple-100/80 shadow-[0_4px_20px_-5px_rgba(127,46,229,0.03)] hover:shadow-[0_10px_25px_-5px_rgba(127,46,229,0.1)] hover:-translate-y-1 transition-all duration-300 group">
                    <div class="w-14 h-14 rounded-xl bg-[#7F2EE5]/10 flex items-center justify-center text-2xl group-hover:bg-[#7F2EE5] group-hover:scale-110 transition-all duration-300 shrink-0">
                        <span class="group-hover:animate-bounce">⚡</span>
                    </div>
                    <div>
                        <h4 class="font-extrabold text-slate-800 text-base group-hover:text-[#7F2EE5] transition-colors">Super Fast Delivery</h4>
                        <p class="text-xs text-slate-400 font-semibold mt-0.5 leading-relaxed">Freshly baked & delivered right to your doorstep in 45 mins.</p>
                    </div>
                </div>
                <div class="flex items-center space-x-5 p-5 bg-white rounded-2xl border border-purple-100/80 shadow-[0_4px_20px_-5px_rgba(127,46,229,0.03)] hover:shadow-[0_10px_25px_-5px_rgba(127,46,229,0.1)] hover:-translate-y-1 transition-all duration-300 group">
                    <div class="w-14 h-14 rounded-xl bg-[#7F2EE5]/10 flex items-center justify-center text-2xl group-hover:bg-[#7F2EE5] group-hover:scale-110 transition-all duration-300 shrink-0">
                        <span class="group-hover:rotate-12 transition-transform">🌱</span>
                    </div>
                    <div>
                        <h4 class="font-extrabold text-slate-800 text-base group-hover:text-[#7F2EE5] transition-colors">100% Organic & Fresh</h4>
                        <p class="text-xs text-slate-400 font-semibold mt-0.5 leading-relaxed">Made with handpicked premium ingredients, completely eggless & pure.</p>
                    </div>
                </div>
                <div class="flex items-center space-x-5 p-5 bg-white rounded-2xl border border-purple-100/80 shadow-[0_4px_20px_-5px_rgba(127,46,229,0.03)] hover:shadow-[0_10px_25px_-5px_rgba(127,46,229,0.1)] hover:-translate-y-1 transition-all duration-300 group">
                    <div class="w-14 h-14 rounded-xl bg-[#7F2EE5]/10 flex items-center justify-center text-2xl group-hover:bg-[#7F2EE5] group-hover:scale-110 transition-all duration-300 shrink-0">
                        <span>🎂</span>
                    </div>
                    <div>
                        <h4 class="font-extrabold text-slate-800 text-base group-hover:text-[#7F2EE5] transition-colors">Custom Designs</h4>
                        <p class="text-xs text-slate-400 font-semibold mt-0.5 leading-relaxed">Turn your imagination into reality. We craft perfection for your special days.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECTION 2: Best Sellers -->
        <section class="space-y-4">
            <div class="flex justify-between items-end border-b border-purple-100/50 pb-2">
                <h3 class="text-2xl font-black text-slate-800 tracking-tight">Best Sellers</h3>
                <a href="/shop?filter=bestsellers" class="text-[#7F2EE5] hover:text-[#6b24c9] font-bold text-sm tracking-wide transition-colors flex items-center gap-1 group">
                    View All <span class="transform group-hover:translate-x-1 transition-transform">&gt;</span>
                </a>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
                {products.map(product => (
                    <ProductCard id={product.id} name={product.name} price={product.price} imageUrl={product.image_url} rating={4.5} deliveryTime="30-45 Min" />
                ))}
            </div>
        </section>

        <!-- SECTION 3: Trending Treats -->
        <section class="space-y-4 mb-10">
            <div class="flex justify-between items-end border-b border-purple-100/50 pb-2">
                <h3 class="text-2xl font-black text-slate-800 tracking-tight">Trending Treats</h3>
                <a href="/shop?filter=trending" class="text-[#7F2EE5] hover:text-[#6b24c9] font-bold text-sm tracking-wide transition-colors flex items-center gap-1 group">
                    View All <span class="transform group-hover:translate-x-1 transition-transform">&gt;</span>
                </a>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
                {[...products].reverse().map(product => (
                    <ProductCard id={product.id} name={product.name} price={product.price} imageUrl={product.image_url} rating={4.5} deliveryTime="30-45 Min" />
                ))}
            </div>
        </section>
		
        <!-- SECTION 4: Dual Multi-Card Offers Slider (Shows 2 Cards at a time) -->
        <section class="relative pt-2 pb-12 overflow-hidden group/offers-slider">
            <div class="offers-slider-wrapper w-full overflow-hidden">
                <div class="offers-slider-track flex transition-transform duration-700 ease-in-out gap-6">
                    {slides.map((slide) => (
                        <div class={`offer-slide-card w-full lg:w-[calc(50%-12px)] shrink-0 flex flex-row items-center justify-between gap-4 p-6 md:p-8 bg-gradient-to-br ${slide.bg} rounded-[24px] border ${slide.border} shadow-sm min-h-[190px]`}>
                            <div class="space-y-2 max-w-xs text-left">
                                <span class={`font-black tracking-widest text-[9px] uppercase px-2.5 py-0.5 rounded-full w-max block ${slide.tagBg}`}>
                                    {slide.tag}
                                </span>
                                <h4 class={`text-2xl font-black tracking-tight leading-tight ${slide.darkText ? 'text-white' : 'text-slate-800'}`} set:html={slide.title}></h4>
                                <p class={`text-[11px] md:text-xs font-semibold leading-relaxed max-w-[220px] ${slide.darkText ? 'text-purple-200/70' : 'text-slate-500'}`}>
                                    {slide.desc}
                                </p>
                                <button class={`text-white font-bold text-[11px] px-4 py-2 rounded-full shadow-lg transition-all transform hover:-translate-y-0.5 mt-1 ${slide.btnBg}`}>
                                    Claim Offer
                                </button>
                            </div>

                            <div class="w-24 h-24 md:w-28 md:h-28 rounded-xl overflow-hidden shadow-xl border-4 border-white transform rotate-3 transition-transform duration-500 shrink-0 relative z-10">
                                <img src={slide.img} alt={slide.tag} class="w-full h-full object-cover scale-105" />
                            </div>
                        </div>
                    ))}
                </div>
            </div>

            <!-- Dots Control: 2 slides loops because total 4 elements / 2 visible at once -->
            <div class="flex items-center justify-center space-x-2 mt-6 z-10">
                <button class="offer-dot-btn w-6 h-2 bg-[#7F2EE5] rounded-full transition-all duration-300" data-slide="0"></button>
                <button class="offer-dot-btn w-2 h-2 bg-purple-200 rounded-full transition-all duration-300" data-slide="1"></button>
                <button class="offer-dot-btn w-2 h-2 bg-purple-200 rounded-full transition-all duration-300" data-slide="2"></button>
            </div>
        </section>

        <!-- SECTION 6: Customer Testimonials -->
        <section class="py-10 border-t border-purple-100/50">
            <div class="text-center max-w-xl mx-auto mb-10">
                <span class="text-[#7F2EE5] font-black text-xs tracking-widest uppercase bg-[#7F2EE5]/10 px-3 py-1 rounded-full">Testimonials</span>
                <h3 class="text-3xl font-black text-slate-800 tracking-tight mt-2">Loved by Sweet Lovers</h3>
                <p class="text-slate-400 text-xs font-semibold mt-1">Our sweet story told through the words of our lovely customers.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="p-6 rounded-2xl bg-white border border-purple-100/60 shadow-sm hover:shadow-md transition-all group">
                    <div class="flex items-center space-x-1 text-amber-400 text-sm mb-3">⭐⭐⭐⭐⭐</div>
                    <p class="text-slate-600 text-xs font-medium leading-relaxed italic">
                        "I ordered a customized Barbie theme cake for my daughter's birthday from here. The cake was not only incredible to look at, but its Black Forest flavor was so fresh that everyone was praising it!"
                    </p>
                    <div class="flex items-center space-x-3 mt-4 pt-3 border-t border-purple-50">
                        <div class="w-9 h-9 rounded-full bg-purple-100 flex items-center justify-center font-bold text-xs text-[#7F2EE5]">R</div>
                        <div>
                            <h5 class="text-xs font-extrabold text-slate-800">Rohan Sharma</h5>
                            <span class="text-[10px] text-slate-400 font-bold">Verified Buyer</span>
                        </div>
                    </div>
                </div>

                <div class="p-6 rounded-2xl bg-white border border-purple-100/60 shadow-sm hover:shadow-md transition-all group">
                    <div class="flex items-center space-x-1 text-amber-400 text-sm mb-3">⭐⭐⭐⭐⭐</div>
                    <p class="text-slate-600 text-xs font-medium leading-relaxed italic">
                        "Their midnight delivery service is truly amazing. The doorbell rang exactly at 12 o'clock at night and we got a completely fresh, warm chocolate truffle cake. Nothing could be better than this for giving a surprise."
                    </p>
                    <div class="flex items-center space-x-3 mt-4 pt-3 border-t border-purple-50">
                        <div class="w-9 h-9 rounded-full bg-pink-100 flex items-center justify-center font-bold text-xs text-pink-600">A</div>
                        <div>
                            <h5 class="text-xs font-extrabold text-slate-800">Ananya Patel</h5>
